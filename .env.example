# Copy to .env and fill in your values.
# Never commit the real .env file.

# Django
DJANGO_SETTINGS_MODULE=config.settings.local

# PostgreSQL (used in Docker and production)
POSTGRES_DB=iotplatform
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot
# DATABASE_URL is derived from the above when running in Docker:
# DATABASE_URL=postgres://iot:iot@postgres:5432/iotplatform
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (defaults to SQLite in local profile; set for Postgres)
# DATABASE_URL=postgres://user:password@localhost:5432/iotplatform

# Gunicorn / container
APP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
PORT=8000

# Celery worker
CELERY_LOG_LEVEL=info
CELERY_WORKER_CONCURRENCY=2

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
# Inside Docker use: redis://redis:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# MQTT — local Mosquitto defaults
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=iot-platform-dev
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=False
MQTT_TOPIC_PREFIX=iot/telemetry

# DTU / Modbus
MODBUS_POLL_INTERVAL=10
MODBUS_TIMEOUT=3
MODBUS_RETRIES=3

# Logging
DJANGO_LOG_LEVEL=INFO
IOT_LOG_LEVEL=DEBUG
